# Bind somente em loopback; a exposicao externa fica por conta do Cloudflare Tunnel.
HOST=127.0.0.1
PORT=10000
NODE_ENV=production

# URL publica do backend e do frontend.
BACKEND_URL=https://saldopro-api.cursar.space
WEB_APP_URL=https://saldopro-98049.web.app

# Caminho do checkout local.
SALDOPRO_REPO_DIR="/media/server/HD Backup/Servidores_NAO_MEXA/SaldoPro"
NODE_BIN=/home/server/.nvm/versions/node/v20.20.0/bin/node
NPM_BIN=/home/server/.nvm/versions/node/v20.20.0/bin/npm

# Sessao do WhatsApp e dados locais persistentes.
WHATSAPP_AUTH_DIR="/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/SaldoPro/whatsapp-auth"
WHATSAPP_AUTH_DIR_WA1="/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/SaldoPro/whatsapp-auth-wa1"
WHATSAPP_API_TOKEN=coloque-um-token-longo-aqui

WHATSAPP_ENABLED=true
WHATSAPP_AUTO_REPLY_ENABLED=true
WHATSAPP_AUTO_REPLY_TEXT="Recebemos sua mensagem. Em breve retornamos."
WHATSAPP_AI_ENABLED=true
WHATSAPP_AI_MAX_RECENT_TX=50
WHATSAPP_AI_HISTORY_LIMIT=10
WHATSAPP_AI_NEW_CONVERSATION_MINUTES=180
WHATSAPP_AI_IMAGE_MAX_BYTES=5242880
WHATSAPP_AI_RATE_LIMIT_PER_MINUTE=10

SUPABASE_URL=https://xwngpybelylzpzefekiw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_SECRET=

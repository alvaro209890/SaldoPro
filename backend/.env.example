PORT=10000
NODE_ENV=production

# URL pública do backend no Render (usado para gerar o link da página do QR nos logs).
# Exemplo: https://saldopro-backend.onrender.com
BACKEND_URL=https://your-app.onrender.com

# Shared API token used to protect backend endpoints.
WHATSAPP_API_TOKEN=replace_with_a_long_random_token

# Auto-reply behavior for inbound messages.
WHATSAPP_AUTO_REPLY_ENABLED=true
WHATSAPP_AUTO_REPLY_TEXT=Recebemos sua mensagem. Em breve retornamos.
WHATSAPP_AI_ENABLED=true
WHATSAPP_AI_MAX_RECENT_TX=50
WHATSAPP_AI_HISTORY_LIMIT=10
WHATSAPP_AI_NEW_CONVERSATION_MINUTES=180
WHATSAPP_AI_IMAGE_MAX_BYTES=5242880
WHATSAPP_AI_RATE_LIMIT_PER_MINUTE=10

# Auth files directory for Baileys. On Render, mount persistent disk here.
WHATSAPP_AUTH_DIR=/opt/render/project/src/backend/.baileys_auth

# Firebase Admin credentials.
# Keep this section because Firebase Auth will continue to be used for ID token verification.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Supabase (data layer)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Groq API for AI-powered WhatsApp handling.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

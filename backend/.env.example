HOST=127.0.0.1
PORT=10000
NODE_ENV=production

# URL publica do backend.
# Exemplo local via Cloudflare Tunnel: https://saldopro-api.cursar.space
BACKEND_URL=https://saldopro-api.cursar.space

# URL publica do frontend hospedado no Firebase Hosting.
# Usada em links de reset de senha, checkout e mensagens do WhatsApp.
WEB_APP_URL=https://cybergis-8ed59.web.app

# Shared API token used to protect backend endpoints.
WHATSAPP_API_TOKEN=replace_with_a_long_random_token

# Auto-reply behavior for inbound messages.
WHATSAPP_AUTO_REPLY_ENABLED=true
WHATSAPP_AUTO_REPLY_TEXT=Recebemos sua mensagem. Em breve retornamos.
WHATSAPP_AI_ENABLED=true
WHATSAPP_AI_MAX_RECENT_TX=50
WHATSAPP_AI_HISTORY_LIMIT=10
WHATSAPP_AI_NEW_CONVERSATION_MINUTES=180
WHATSAPP_AI_IMAGE_MAX_BYTES=5242880
WHATSAPP_AI_RATE_LIMIT_PER_MINUTE=10

# Auth files directory for Baileys. On Render, mount persistent disk here.
WHATSAPP_AUTH_DIR=/opt/render/project/src/backend/.baileys_auth

# Firebase Admin credentials.
# Pode ser informado inline ou via arquivo JSON da service account.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=/media/server/HD Backup/Servidores_NAO_MEXA/SaldoPro/cybergis-8ed59-firebase-adminsdk.json

# Firebase Web API Key (obrigatorio).
# Usado para autenticacao via REST (login, lookup e refresh de token).
# E o mesmo valor de VITE_FIREBASE_API_KEY do frontend (comeca com AIzaSy...).
FIREBASE_WEB_API_KEY=

# Supabase (data layer)
SUPABASE_URL=https://xwngpybelylzpzefekiw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional alias used by newer Supabase dashboard naming.
# If set, it can replace SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SECRET_KEY=

# Groq API for AI-powered WhatsApp handling.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_VISION_MODEL=meta-llama/llama-4-maverick-17b-128e-instruct
GROQ_TIMEOUT_MS=15000
GROQ_MAX_RETRIES=2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
